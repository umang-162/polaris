# ---------------------------------------------------------------------------
# Polaris — environment variables
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# NEXT_PUBLIC_* values are exposed to the browser; everything else is server-side.
# ---------------------------------------------------------------------------

# --- Convex (realtime DB + file storage) ---
# Printed by `npx convex dev` on first run.
NEXT_PUBLIC_CONVEX_URL=

# Set these on the CONVEX deployment (Convex dashboard or `npx convex env set NAME value`),
# not just in .env.local — they are read inside Convex functions.
# Clerk JWT issuer domain, paired with a Clerk JWT template whose application ID is "convex".
CLERK_JWT_ISSUER_DOMAIN=
# Shared secret that gates the Convex system.* namespace (trusted server jobs / the agent).
# Generate a long random string, e.g.  openssl rand -hex 32
POLARIS_CONVEX_INTERNAL_KEY=

# --- Clerk (authentication + Pro-plan gating + GitHub OAuth tokens) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Google Gemini (Vercel AI SDK @ai-sdk/google) ---
# Used by the coding agent, title generation, quick-edit, and inline suggestions.
GOOGLE_GENERATIVE_AI_API_KEY=

# --- Firecrawl (URL -> markdown scraping for the agent's scrapeUrls tool) ---
FIRECRAWL_API_KEY=

# ---------------------------------------------------------------------------
# Managed automatically — do NOT set these yourself:
#   CI           -> set by your CI provider; toggles Sentry's silent build option
#   NEXT_RUNTIME -> set by Next.js (nodejs | edge) to pick the Sentry config
# ---------------------------------------------------------------------------
